datasource db {
  provider = "postgresql"

}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  guest
  user
  admin
}

enum UserTier {
  free
  premium
}

enum CEFRLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  image    String?

  role  UserRole @default(user)
  tier  UserTier @default(free)
  level String   @default("Beginner")

  stats UserStats?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  speechAttempts SpeechAttempt[]
  videoHistories VideoHistory[]
  vocabularies   UserVocabulary[]
  videoProgress  UserProgress[]

  comments Comment[]

  leaderboard Leaderboard?
}

model UserStats {
  id     String @id @default(cuid())
  userId String @unique

  streak Int @default(0)
  videos Int @default(0)

  rank      Int @default(0)
  studyTime Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id        String   @id @default(cuid())

  userId    String
  videoId   String

  progress  Int      @default(0) //
  completed Boolean  @default(false)

  lastTime  Int      @default(0) //
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

model Topic {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  description String?
  videos Video[]
}

model Video {
  id        String    @id @default(cuid())
  title     String?
  url       String?
  youtubeId String    @unique
  topicId   String?
  level     CEFRLevel @default(A1)
  tier      UserTier @default(free)
  createdAt DateTime  @default(now())

  topic Topic? @relation(fields: [topicId], references: [id])

  subtitles      SubtitleSentence[]
  videoHistories VideoHistory[]
  videoProgress  UserProgress[]
  Comment Comment[]
}

model VideoHistory {
  id       String @id @default(cuid())
  userId   String
  videoId  String
  progress Float  @default(0)
  lastTime Float  @default(0)

  watchedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model SubtitleSentence {
  id        String @id @default(cuid())
  videoId   String
  startTime Float
  endTime   Float
  text      String

  video          Video           @relation(fields: [videoId], references: [id])
  speechAttempts SpeechAttempt[]
}

model SpeechAttempt {
  id String @id @default(cuid())

  userId     String
  subtitleId String

  audioUrl String

  transcript String
  reference  String

  wer   Float
  score Float

  createdAt DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id])
  subtitle SubtitleSentence @relation(fields: [subtitleId], references: [id])
}

model Vocabulary {
  id String @id @default(cuid())

  word          String
  meaning       String
  example       String?
  pronunciation String?
  tier          UserTier @default(free)
  level CEFRLevel?

  createdAt DateTime @default(now())

  users UserVocabulary[]
}

model UserVocabulary {
  id String @id @default(cuid())

  userId       String
  vocabularyId String

  learned Boolean @default(false)

  createdAt DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id])

  @@unique([userId, vocabularyId])
}

model Comment {
  id String @id @default(cuid())

  userId  String
  videoId String?

  content String

  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  video Video? @relation(fields: [videoId], references: [id])
}

model Leaderboard {
  id String @id @default(cuid())

  userId String @unique

  xp    Int @default(0)
  rank  Int @default(0)
  level Int @default(1)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
